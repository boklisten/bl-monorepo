{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun build:backend",
    "watchPatterns": ["backend/**", "package.json", "bun.lock"]
  },
  "deploy": {
    "preDeployCommand": "bun migrate:backend",
    "startCommand": "bun start:backend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "cronSchedule": null,
    "multiRegionConfig": {
      "europe-west4-drams3a": { "numReplicas": 1 }
    }
  },
  "environments": {
    "staging": {
      "deploy": { "sleepApplication": true }
    },
    "production": {
      "deploy": { "sleepApplication": false }
    }
  }
}
