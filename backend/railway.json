{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "bun build:backend",
    "watchPatterns": ["backend/**", "package.json", "bun.lock"]
  },
  "deploy": {
    "preDeployCommand": "bun migrate:backend",
    "startCommand": "bun start:backend",
    "healthcheckPath": "/health"
  }
}
