{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun build:frontend",
    "watchPatterns": [
      "frontend/**",
      "backend/shared/**",
      "backend/.adonisjs/**",
      "package.json",
      "bun.lock"
    ]
  },
  "deploy": {
    "startCommand": "bun start:frontend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "cronSchedule": null,
    "multiRegionConfig": {
      "europe-west4-drams3a": { "numReplicas": 1 }
    }
  },
  "environments": {
    "staging": {
      "deploy": { "sleepApplication": true }
    },
    "production": {
      "deploy": { "sleepApplication": false }
    }
  }
}
