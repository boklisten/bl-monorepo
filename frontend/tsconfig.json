{
  "extends": ["@tsconfig/strictest/tsconfig.json", "@tsconfig/next/tsconfig.json"],
  "compilerOptions": {
    "exactOptionalPropertyTypes": false, // fixme: delete this line for stricter checks
    "noUnusedParameters": false, // fixme: delete this line for stricter checks
    "target": "es2022",
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./src/*"],
      "@boklisten/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
