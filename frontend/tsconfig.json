{
  "extends": ["@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    // "verbatimModuleSyntax": true, fixme: enable to improve imports
    "noEmit": true,

    "exactOptionalPropertyTypes": false, // fixme: delete this line for stricter checks
    "noUnusedParameters": false, // fixme: delete this line for stricter checks
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./src/*"],
      "@boklisten/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../backend/**/*.ts", "../backend/.adonisjs/**/*.ts"],
  "exclude": ["node_modules", "../backend/build", "../backend/node_modules"]
}
