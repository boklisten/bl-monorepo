{
  "extends": ["@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx",
    "module": "ESNext", // fixme: consider using an older target to prevent errors in outdated browsers
    "baseUrl": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // "verbatimModuleSyntax": true, fixme: enable to improve imports
    "noEmit": true,

    "exactOptionalPropertyTypes": false, // fixme: delete this line for stricter checks
    "noUnusedParameters": false, // fixme: delete this line for stricter checks
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./src/*"],
      "@boklisten/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
