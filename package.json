{
  "name": "boklisten.no",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": {
    "packages": [
      "frontend",
      "backend"
    ],
    "catalog": {
      "@tsconfig/strictest": "^2.0.8",
      "@tuyau/core": "^1.2.2",
      "@tuyau/superjson": "^1.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "ace": "bun --filter './backend' ace",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun --workspaces --parallel run typecheck",
    "fix": "bun --parallel lint:fix typecheck && bun format",
    "test": "bun --workspaces run test",
    "dev": "bun --workspaces --parallel dev",
    "build:frontend": "bun --filter './frontend' build",
    "build:backend": "bun --filter './backend' build",
    "build": "bun --workspaces --parallel run build",
    "migrate:backend": "bun --filter './backend' migrate",
    "start:frontend": "bun --filter './frontend' start",
    "start:backend": "bun --filter './backend' start",
    "start": "bun --workspaces --parallel start"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "6.0.2"
  },
  "overrides": {
    "@adonisjs/assembler": "^8.4.0",
    "@tanstack/query-core": "5.96.0",
    "@tanstack/react-query": "5.96.0"
  }
}
