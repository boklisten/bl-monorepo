{
  "name": "boklisten.no",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": {
    "packages": [
      "frontend",
      "backend"
    ],
    "catalog": {
      "@tuyau/core": "^1.2.2",
      "@tuyau/superjson": "^1.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "ace": "bun --filter './backend' ace",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun --workspaces --parallel run typecheck",
    "fix": "bun --parallel lint:fix typecheck && bun format",
    "test": "bun --workspaces run test",
    "dev": "bun --workspaces --parallel dev",
    "build:frontend": "bun --filter './frontend' build",
    "build:backend": "bun --filter './backend' build",
    "build": "bun --workspaces --parallel build",
    "start": "bun --workspaces --parallel start"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "5.9.3"
  }
}
