{
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "ace": "pnpm -F backend exec node ace",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "pnpm -r typecheck",
    "fix": "pnpm -wr '/^(lint:fix|typecheck)$/' && pnpm format",
    "test": "pnpm -r test",
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm -F backend build && (pnpm -F backend start & pnpm -F frontend build && pnpm -F frontend start)"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.3.5",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "typescript": "^5.9.3"
  }
}
